          <div class="ex-card">
            <div class="ex-name">Plancha abdominal</div>
            <div class="ex-stats">
              <div class="ex-stat">
                <div class="ex-stat-val">3</div>
                <div class="ex-stat-lbl">series</div>
              </div>
              <div class="ex-stat">
                <div class="ex-stat-val">20 s</div>
                <div class="ex-stat-lbl">duración</div>
              </div>
              <div class="ex-stat">
